# Vite reads .env / .env.local / .env.{mode} from this directory at build
# time. Only variables prefixed with `VITE_` reach the bundle — anything
# else is invisible to the browser.

# Tagged on every export and shown in About panes so regressions can be
# traced back to a release. Resolves to `dev` when unset.
VITE_RELEASE_VERSION=
