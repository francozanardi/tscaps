{
  "name": "Mira",
  "categories": [
    "clean"
  ],
  "typography": {
    "fontFamily": "Montserrat Variable",
    "fontWeight": 600,
    "fontSize": 3.9,
    "letterSpacing": 0,
    "wordSpacing": 0.13,
    "textAlign": "center"
  },
  "styleControls": [
    {
      "id": "primary-color",
      "label": "Text",
      "type": "color",
      "default": "#ffffff",
      "group": "colors"
    },
    {
      "id": "quote-color",
      "label": "Quote",
      "type": "color",
      "default": "#e6d647",
      "group": "colors"
    },
    {
      "id": "shadow-color",
      "label": "Shadow",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-color",
      "label": "Outline",
      "type": "color",
      "default": "#000000",
      "advanced": true,
      "group": "colors"
    },
    {
      "id": "outline-thickness",
      "label": "Outline thickness",
      "type": "float",
      "default": 0.16,
      "min": 0,
      "max": 0.3,
      "step": 0.01,
      "unit": "em",
      "group": "appearance"
    },
    {
      "id": "shadow-distance",
      "label": "Shadow distance",
      "type": "float",
      "default": 0.08,
      "min": 0,
      "max": 1.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "shadow-blur",
      "label": "Shadow blur",
      "type": "float",
      "default": 0.4,
      "min": 0,
      "max": 2.0,
      "step": 0.01,
      "unit": "em",
      "advanced": true,
      "group": "appearance"
    },
    {
      "id": "slide-distance",
      "label": "Slide distance",
      "type": "float",
      "default": 0.08,
      "min": 0,
      "max": 0.8,
      "step": 0.01,
      "unit": "em",
      "group": "appearance",
      "legend": "Distance the segment slides down on entry. 0 disables the slide."
    },
    {
      "id": "tag-weight",
      "label": "Tag weight",
      "type": "integer",
      "default": 900,
      "min": 100,
      "max": 900,
      "step": 100,
      "group": "appearance",
      "legend": "Weight for tagged words (emphasis, accent, entity)."
    },
    {
      "id": "quote-italic",
      "label": "Italic quotes",
      "type": "toggle",
      "default": true,
      "valueOn": "italic",
      "valueOff": "normal",
      "group": "appearance"
    }
  ],
  "segmentSplitters": [
    {
      "type": "boundary",
      "mode": "clause"
    },
    {
      "type": "limit_by_scaled_chars",
      "maxChars": 18,
      "minChars": 7
    }
  ],
  "lineSplitter": {
    "type": "balanced-pixel-width",
    "minLines": 1,
    "maxLines": 1,
    "maxWidthRatio": 0.8
  },
  "alignment": {
    "verticalAlign": "bottom",
    "verticalOffset": 0.65,
    "horizontalAlign": "center",
    "horizontalOffset": 0.5
  },
  "effects": [
    {
      "type": "gap_free",
      "enabled": true
    },
    {
      "type": "remove_punctuation",
      "enabled": true
    },
    {
      "type": "carry_quotes",
      "enabled": true
    },
    {
      "type": "smart_punctuation",
      "enabled": true
    },
    {
      "type": "smart_lowercase",
      "enabled": true
    }
  ]
}
